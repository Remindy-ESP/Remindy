# API Configuration
# For local development, use your ngrok static domain
# See: https://dashboard.ngrok.com/domains
EXPO_PUBLIC_BACKEND_API_URL=https://your-ngrok-domain.ngrok-free.dev
EXPO_PUBLIC_BACKEND_API_TIMEOUT=30000
EXPO_PUBLIC_ENV=local

# OAuth Configuration
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxx.apps.googleusercontent.com
