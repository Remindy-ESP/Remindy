# Variables d'environnement sensibles
.env
*.env

# Inventaires générés dynamiquement (contiennent les IPs)
inventories/hosts.ini
inventories/hosts.*.backup.*

# Fichiers système macOS
.DS_Store
.DS_*

# Logs Ansible
*.log
*.retry

# Fichiers temporaires
*.tmp
*.swp
*~

# Vault password files
.vault_pass
vault_pass.txt

# Collections et roles téléchargés
collections/
roles/*/

# Cache Ansible
.ansible/
__pycache__/
*.pyc