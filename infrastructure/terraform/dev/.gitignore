# Terraform directories
.terraform/
.terraform.*

# State files (contiennent les IPs, IDs de ressources, etc.)
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Variables sensibles (mots de passe, clés SSH, etc.)
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc