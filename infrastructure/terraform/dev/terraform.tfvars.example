# Project Configuration
project_name = "remindy"
environment  = "dev"
location     = "West Europe"

# VM Configuration
vm_count       = 1
vm_size        = "Standard_B1s"
admin_username = "remindy"
admin_password = "your-secure-password"  # Optional: set password or use SSH key only
app_port       = 3000

# SSH Configuration (required)
ssh_public_key = "ssh-rsa AAAAB3NzaC1yt1SgOhLENl...Pdq/tkF/s3XU/RO9xjfoAdPGbOwKPnV4zyI8u5ZrFTQ== remindy-user@remindy"

# Ansible SSH Configuration
ansible_ssh_public_key = "ssh-rsa AAAAB3NzaC1yt1SgOhLENl...Pdq/tkF/s3XU/RO9xjfoAdPGbOwKPnV4zyI8u5ZrFTQ== remindy-user@remindy"

# Security Configuration
allowed_ips = [
  "YOUR_IP_ADDRESS/32",  # Replace with your public IP
  "OFFICE_IP_RANGE/24"   # Add your office IP range if needed
]

# Resource Tags
tags = {
  Project     = "Remindy"
  Environment = "dev"
  ManagedBy   = "Terraform"
  Owner       = "DevOps-Team"
}